# App Configuration
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database Configuration (MySQL)
DATABASE_URL=mysql://db_user:db_password@localhost:3306/db_name

# Authentication Secrets
# Generate secure keys using: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_key_here
JWT_ACCESS_SECRET=your_jwt_access_secret_key_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key_here

# Token Expirations
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Brevo (MFA Email Dispatch)
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=NutriON

# Gemini AI Engine (Calorie & Nutrition Tips)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FALLBACK_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# USDA FoodData Central API (Optional, defaults to DEMO_KEY if blank)
USDA_API_KEY=DEMO_KEY
